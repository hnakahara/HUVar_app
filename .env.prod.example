# ---- 本番環境用 環境変数テンプレート ----
# 実際の値を入れて .env.prod として保存する（.env.prod はリポジトリ非追跡）

# Django
DEBUG=0
SECRET_KEY=__REPLACE_WITH_STRONG_RANDOM_SECRET__
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_ALLOWED_HOSTS=1603-027.a.hiroshima-u.ac.jp

# サブパス（vas と同一ドメインの /acmg 配下で提供）
FORCE_SCRIPT_NAME=/acmg

# PostgreSQL
POSTGRES_NAME=huhvar
POSTGRES_USER=huhvar
POSTGRES_PASSWORD=__REPLACE__
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://:__REPLACE__@redis:6379/0
REDIS_PASSWORD=__REPLACE__

# TransVar サービス
TRANSVAR_SERVICE_URL=http://transvar:5000

# 管理者通知（アカウント発行リクエスト先）
ADMIN_ADDRESS=
GMAIL_ADDRESS=
GMAIL_PASS=

# ジョブ成果物（アップロードVCF・生成TSV）の保持時間（時間）
JOB_ARTIFACT_RETENTION_HOURS=1
