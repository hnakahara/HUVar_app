# ---- テスト環境用 環境変数テンプレート ----
# 実際の値を入れて .env として保存する（.env はリポジトリ非追跡）

# Django
DEBUG=1
SECRET_KEY=change-me-in-real-env
DJANGO_SETTINGS_MODULE=config.settings.test
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# サブパス（vas と同一ドメインの /acmg 配下で提供）
FORCE_SCRIPT_NAME=/acmg

# PostgreSQL
POSTGRES_NAME=huvar
POSTGRES_USER=huvar
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me

# TransVar サービス
TRANSVAR_SERVICE_URL=http://transvar:5000

# 管理者通知（アカウント発行リクエスト先）
ADMIN_ADDRESS=
GMAIL_ADDRESS=
GMAIL_PASS=

# ジョブ成果物（アップロードVCF・生成TSV）の保持時間（時間）
JOB_ARTIFACT_RETENTION_HOURS=1
